# Provider de LLM
# - none   : sem LLM (modo offline, só retrieval + regras)
# - ollama : LLM local via Ollama
# - openai : API (use com cuidado de custo)
LLM_PROVIDER=none

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Limites gerais
TOP_K=5
MAX_CONTEXT_CHARS=12000
MAX_TOKENS=600
TEMPERATURE=0.2
